{
  "name": "base-converter",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Basi numeriche e codifiche — toolkit didattico: conversioni con passaggi, aritmetica in base, complemento a due, IEEE 754, ASCII/Unicode, palestra con badge e verifiche ufficiali",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:functions": "tsc -p tsconfig.functions.json",
    "pages:dev": "wrangler pages dev dist --port 8788"
  },
  "dependencies": {
    "lucide-react": "^0.554.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260112.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
